<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inventory_feed" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inventory.feed</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='stock']/block[@name='warehouse_setting_container']" position="after">
                <block title="Inventory Feed" name="inventory_feed_setting_container">
                    <setting id="inventory_feed_connection" string="API Connection" help="Fetch inventory rows from the configured source collection.">
                        <div class="content-group">
                            <div class="row mt8">
                                <label for="inventory_feed_base_url" class="col-lg-3 o_light_label"/>
                                <field name="inventory_feed_base_url" class="col-lg-9"/>
                            </div>
                            <div class="row mt8">
                                <label for="inventory_feed_collection" class="col-lg-3 o_light_label"/>
                                <field name="inventory_feed_collection" class="col-lg-9"/>
                            </div>
                            <div class="row mt8">
                                <label for="inventory_feed_auth_mode" class="col-lg-3 o_light_label"/>
                                <field name="inventory_feed_auth_mode" class="col-lg-9"/>
                            </div>
                            <div class="row mt8">
                                <label for="inventory_feed_token" class="col-lg-3 o_light_label"/>
                                <field name="inventory_feed_token" password="True" class="col-lg-9"/>
                            </div>
                            <div class="row mt8">
                                <label for="inventory_feed_page_size" class="col-lg-3 o_light_label"/>
                                <field name="inventory_feed_page_size" class="col-lg-9"/>
                            </div>
                        </div>
                    </setting>
                    <setting id="inventory_feed_creation" string="Missing Data" help="Create Odoo records when the feed has a new store or SKU.">
                        <field name="inventory_feed_auto_create_stores"/>
                        <div class="content-group">
                            <div class="mt8">
                                <field name="inventory_feed_auto_create_locations"/>
                                <label for="inventory_feed_auto_create_locations"/>
                            </div>
                            <div class="mt8">
                                <field name="inventory_feed_auto_create_products"/>
                                <label for="inventory_feed_auto_create_products"/>
                            </div>
                        </div>
                    </setting>
                    <setting id="inventory_feed_actions" string="Manual Sync" help="Run the same sync logic used by the daily scheduled action.">
                        <button name="action_sync_stores" type="object" string="Sync Stores" class="btn-link" icon="oi-arrow-right"/>
                        <br/>
                        <button name="action_sync_inventory" type="object" string="Sync Inventory" class="btn-link" icon="oi-arrow-right"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
