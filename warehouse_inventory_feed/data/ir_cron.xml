<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_inventory_feed_sync" model="ir.cron">
        <field name="name">Inventory Feed: daily sync</field>
        <field name="model_id" ref="model_inventory_feed_sync_log"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_inventory()</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=0, minute=0, second=0, microsecond=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>
</odoo>
